# Example environment variables for secrets (do NOT commit real secrets)
# Populate these in your deployment environment or secret manager.

# Mailchimp API Key
MAILCHIMP_KEY=

# Mailgun Private API Token
MAILGUN_KEY=

# Mailgun Webhook Key
MAILGUN_SIGNING=

# New Relic User API ID (64 chars)
NEW_RELIC_USER_API_ID=

# New Relic User API Key (starts with NRAK-)
NEW_RELIC_USER_API_KEY=

# Hashicorp Terraform Token
TERRAFORM_TOKEN=